# OpenAI 兼容接口配置（豆包 / DeepSeek）
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_CHAT_MODEL=doubao-pro-32k-241215

# 豆包 Embedding 模型名。
# 官方 Ark SDK 示例使用 doubao-embedding-large-text-250515，
# 通过 OpenAI 兼容接口调用时同样使用该模型名。
# 注意：该模型默认输出维度为 2048（支持 MRL 截断到 1024/512/256），
# 请同步修改 application.yml / docker-compose.yml 中的 vector.milvus.dimension，
# 使其与所选模型实际输出维度保持一致。
OPENAI_EMBEDDING_MODEL=doubao-embedding-large-text-250515

# Spring AI Alibaba 通义千问配置（可选）
ALI_AI_API_KEY=your-dashscope-api-key

# Nacos 配置（docker-compose 中已硬编码，本地开发可覆盖）
# NACOS_SERVER_ADDR=127.0.0.1:8848
# NACOS_USERNAME=nacos
# NACOS_PASSWORD=nacos

# Redis 配置（docker-compose 中已硬编码，本地开发可覆盖）
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# 向量库配置（docker-compose 中已硬编码）
# MILVUS_HOST=127.0.0.1
# MILVUS_PORT=19530
# Milvus collection 维度，需与 Embedding 模型输出维度一致
# MILVUS_DIMENSION=2048
# ES_HOSTS=http://127.0.0.1:9200
